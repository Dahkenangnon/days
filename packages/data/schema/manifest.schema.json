{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://days.claviscore.com/schema/manifest.schema.json",
  "title": "ManifestRecord",
  "type": "object",
  "required": [
    "schemaVersion", "lastUpdated", "countries", "yearsAvailable",
    "baseUrl", "endpoints", "schemaUrls"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "lastUpdated":   { "type": "string", "format": "date" },
    "countries": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z]{2}$" }
    },
    "yearsAvailable": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 2000 }
    },
    "baseUrl": { "type": "string", "format": "uri" },
    "endpoints": {
      "type": "object",
      "required": ["day", "month", "year", "manifest"],
      "additionalProperties": false,
      "properties": {
        "day":      { "type": "string" },
        "month":    { "type": "string" },
        "year":     { "type": "string" },
        "manifest": { "type": "string" }
      }
    },
    "schemaUrls": {
      "type": "object",
      "required": ["day", "month", "year", "manifest"],
      "additionalProperties": false,
      "properties": {
        "day":      { "type": "string" },
        "month":    { "type": "string" },
        "year":     { "type": "string" },
        "manifest": { "type": "string" }
      }
    }
  }
}
